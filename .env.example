APP_ID=your_instagram_app_id
APP_SECRET=your_instagram_app_secret
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=sellpilot
FRONTEND_URL=http://localhost:8080
FRONTEND_REDIRECT_PATH=/dashboard
COOKIE_NAME=sellpilot_session
COOKIE_SECRET=replace_with_a_long_random_secret
REDIRECT_URI=https://your-ngrok-domain.ngrok-free.app/api/auth/callback
LOG_LEVEL=INFO

# Use COOKIE_SAMESITE=none and COOKIE_SECURE=true when the frontend runs on
# localhost and calls this API through HTTPS ngrok.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
